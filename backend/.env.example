# Copy this file to .env and fill in real values for local development.
# Never commit the real .env file — it is gitignored.
#
# Config groups are nested with "__" (double underscore), e.g.
# APPLICATION__PORT sets Settings.application.port. See
# app/core/settings.py for the full validated schema and
# app/core/config.py for how it's loaded as a singleton.
#
# Every value below is the same as the built-in default — you only need to
# uncomment/change what you want to override. An empty backend/.env (or no
# file at all) is a valid, working local configuration.

# --- Application ---
APPLICATION__NAME=product-intelligence-backend
APPLICATION__ENVIRONMENT=local        # local | development | staging | production | test
APPLICATION__DEBUG=true
APPLICATION__HOST=0.0.0.0
APPLICATION__PORT=8000

# --- Database ---
# SQLite is fine for local dev. Production must use a real database —
# Settings raises a validation error at startup if it doesn't.
DATABASE__URL=sqlite+aiosqlite:///./storage/app.db
DATABASE__ECHO=false
DATABASE__POOL_SIZE=5

# --- AI Models ---
# No AI calls are made yet (that starts in a later phase) — leave the key
# blank for now.
AI_MODELS__OPENAI_API_KEY=
AI_MODELS__EMBEDDING_MODEL=text-embedding-3-small
AI_MODELS__LLM_MODEL=gpt-4o-mini
AI_MODELS__REQUEST_TIMEOUT_SECONDS=30

# --- Storage ---
STORAGE__UPLOAD_DIR=./storage/uploads
STORAGE__MAX_UPLOAD_SIZE_MB=10

# --- Security ---
# REQUIRED in production: startup fails if this is still the default value.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECURITY__SECRET_KEY=insecure-dev-secret-key-change-me-1234567890
SECURITY__ALGORITHM=HS256
SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Logging ---
LOGGING__LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOGGING__JSON_LOGS=false
